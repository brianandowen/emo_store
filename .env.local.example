# ============================================================
#  .env.local 範例
# ============================================================
#  ★ 重要：這個純前端版本「不需要任何環境變數」就能跑。
#    計分與推薦全部在瀏覽器端完成，不連資料庫。
#
#  以下變數是「之後若你想加 Neon 統計功能」才需要填寫。
#  目前可以整份留白或不建立 .env.local，專案一樣能正常運作。
# ------------------------------------------------------------

# Neon PostgreSQL 連線字串（選用）
# 從 Neon Dashboard → 你的專案 → Connection Details 複製
# 形如：postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# 如果使用 Vercel 的 Neon 整合，可能會自動帶入這兩個：
# DATABASE_URL_UNPOOLED=
# POSTGRES_URL=
